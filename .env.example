# Groq API kulcs: https://console.groq.com → API Keys
GROQ_API_KEY=your_groq_api_key_here

# Opcionális: Groq modell (ha limitben más nevet állítottál)
# Példák: llama-3.1-8b-instant, llama-3.3-70b-versatile
GROQ_MODEL=llama-3.1-8b-instant

# Másodperc várakozás PDF chunkok között (429 elkerülésére). 2 RPM ≈ 30, magasabb limitnál 2–5
# GROQ_DELAY_BETWEEN_REQUESTS=30

# Alapértelmezett PDF mappa (ha a szerver nem találja a pdf/ mappát, add meg a teljes útvonalat)
# PDF_DIR=/Users/sitkeitamas/Documents/GitHub/PDFAI/pdf

# Reverse proxy path prefix (pl. Synology: https://nas.local/pdfai/ -> APP_PREFIX=/pdfai)
# APP_PREFIX=/pdfai
